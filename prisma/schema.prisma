  docId        BigInt?    @map("doc_id") @db.UnsignedBigInt
  siId         BigInt?    @map("si_id") @db.UnsignedBigInt
  preissueId   BigInt?    @map("preissue_id") @db.UnsignedBigInt
  requestId    String?    @map("request_id") @db.VarChar(128)
