model ExportJob {
  exportJobId      BigInt        @id @default(autoincrement()) @map("export_job_id") @db.UnsignedBigInt
  projectId        BigInt        @map("project_id") @db.UnsignedBigInt
  scope            ExportScope   @map("scope")
  format           ExportFormat  @default(docx) @map("format")
  sourceDocId      BigInt?       @map("source_doc_id") @db.UnsignedBigInt
  sourceRevisionId BigInt?       @map("source_revision_id") @db.UnsignedBigInt
  status           ExportStatus  @default(pending) @map("status")
  filePath         String?       @map("file_path") @db.VarChar(1000)
  errorMessage     String?       @map("error_message") @db.Text
  requestedBy      BigInt        @map("requested_by") @db.UnsignedBigInt
  createdAt        DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  startedAt        DateTime?     @map("started_at") @db.DateTime(3)
  completedAt      DateTime?     @map("completed_at") @db.DateTime(3)

  project          Project       @relation(fields: [projectId], references: [projectId], onDelete: Cascade, onUpdate: NoAction)
  sourceDoc        Doc?          @relation(fields: [sourceDocId], references: [docId], onDelete: SetNull, onUpdate: NoAction)
  sourceRevision   DocRevision?  @relation(fields: [sourceRevisionId], references: [revisionId], onDelete: SetNull, onUpdate: NoAction)
  requester        User          @relation(fields: [requestedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)

  @@map("export_jobs")
  @@index([projectId, createdAt], map: "idx_export_jobs_project_created")
  @@index([requestedBy, createdAt], map: "idx_export_jobs_requested_by")
  @@index([status], map: "idx_export_jobs_status")
}
